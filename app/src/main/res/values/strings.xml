    <string name="admin_section_title">הרשאת מנהל מכשיר (הרתעת גניבה)</string>
    <string name="admin_section_desc">חשוב: זו הרתעה בלבד ולא הגנה אמיתית מפני הסרה. אנדרואיד מאפשר לכל אחד לבטל הרשאת מנהל דרך ההגדרות - האפליקציה רק תנעל את המסך מיד כשמנסים לבטל, ולא יכולה לחסום את זה בסיסמה משלה.</string>
    <string name="admin_status_on">מצב: פעיל</string>
    <string name="admin_status_off">מצב: כבוי</string>
    <string name="enable_admin">הפעל הגנת מנהל מכשיר</string>
    <string name="disable_admin">כבה הגנת מנהל מכשיר</string>
    <string name="admin_add_explanation">מאפשר לאפליקציה לנעול את המסך מיד אם מישהו ינסה לבטל את ההרשאה הזו - הרתעת גניבה בלבד.</string>
    <string name="admin_not_supported">המכשיר הזה לא תומך בהרשאות מנהל מכשיר</string>
    <string name="admin_enabled_toast">הגנת מנהל מכשיר הופעלה</string>
    <string name="admin_disabled_toast">הגנת מנהל מכשיר כובתה</string>
    <string name="admin_disable_warning">שימו לב: ביטול הרשאה זו יסיר את הגנת ההרתעה מפני גניבה. המסך ננעל כעת.</string>

    <string name="battery_section_title">מניעת סגירת השירות ברקע</string>
    <string name="battery_section_desc">אם השכבות נעלמות אחרי סגירת האפליקציה מ\"יישומים אחרונים\", תנו לאפליקציה פטור מניהול סוללה כדי שהשירות ימשיך לרוץ</string>
    <string name="request_battery_exemption">בקש פטור מאופטימיזציית סוללה</string>
    <string name="battery_exemption_not_needed">גרסת אנדרואיד זו לא סוגרת שירותים בגלל סוללה</string>
    <string name="battery_exemption_already_granted">הפטור כבר ניתן</string>
    <string name="battery_exemption_unavailable">המכשיר לא תומך במסך הזה - חפשו \"ניהול סוללה\" בהגדרות היצרן</string>

    <string name="notification_section_title">התראה קבועה בוילון ההתראות</string>
    <string name="notification_section_desc">מ-Android 8 ומעלה, אנדרואיד מחייב התראה גלויה כל עוד השירות רץ \"בפעולת חזית\" (foreground) - זו הדרך שהמערכת שומרת על שקיפות לגבי מה שרץ ברקע, ולא ניתן לעקוף אותה טכנית. אם ההתראה מפריעה לכם, אפשר לכבות אותה - אבל אז השירות עובר להיות שירות רגיל, ואנדרואיד עלול לסגור אותו מעצמו אחרי זמן מה כשהאפליקציה לא בחזית (כלומר השכבות עלולות להיעלם מדי פעם וידרשו הפעלה מחדש). אם השכבות חשובות לכם שיישארו יציבות לאורך זמן, מומלץ להשאיר את ההתראה דלוקה.</string>
    <string name="notification_status_on">התראה: מוצגת</string>
    <string name="notification_status_off">התראה: מוסתרת (השירות פחות יציב ברקע)</string>
    <string name="hide_notification">הסתר את ההתראה</string>
    <string name="show_notification_action">הצג את ההתראה מחדש</string>
    <string name="notification_hidden_toast">ההתראה הוסתרה. אם השכבות נעלמות אחרי זמן, זה בגלל שהמערכת סגרה את השירות - אפשר להחזיר את ההתראה בכל עת מכאן.</string>
    <string name="notification_shown_toast">ההתראה הוצגה מחדש</string>
