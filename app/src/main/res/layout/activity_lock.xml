<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <TextView
        android:id="@+id/textOwnerInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/textLockTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginBottom="16dp" />

    <EditText
        android:id="@+id/fieldPin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:inputType="numberPassword"
        android:gravity="center"
        android:hint="@string/pin_hint" />

    <EditText
        android:id="@+id/fieldPinConfirm"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:inputType="numberPassword"
        android:gravity="center"
        android:layout_marginTop="8dp"
        android:hint="@string/pin_confirm_hint"
        android:visibility="gone" />

    <Button
        android:id="@+id/buttonUnlock"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/unlock" />

    <Button
        android:id="@+id/buttonSkipPin"
        android:layout_width="200dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:background="@android:color/transparent"
        android:textAllCaps="false"
        android:visibility="gone"
        android:text="@string/skip_pin_setup" />

</LinearLayout>
