<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Draw floating layers over other apps (equivalent of WS_EX_LAYERED | WS_EX_TOPMOST) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Keep the overlay(s) alive in the background -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Required to show the persistent notification on Android 13+ (equivalent of the tray icon) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Optional: relaunch the overlay service after a reboot (equivalent of "auto-start with Windows") -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Required to even show the "ignore battery optimizations" system dialog (SecurityActivity's
         battery-exemption button). Without this, Settings.ACTION_REQUEST_IGNORE_BATTERY_OPTIMIZATIONS
         throws a SecurityException at the OS level and the button silently does nothing. -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.OverlayManager"
        android:supportsRtl="true">

        <activity
            android:name=".LockActivity"
            android:exported="true"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:launchMode="singleTop" />

        <activity
            android:name=".SecurityActivity"
            android:exported="false"
            android:label="@string/security_title" />

        <activity
            android:name=".LayerEditActivity"
            android:exported="false"
            android:label="@string/edit_layer_title" />

        <receiver
            android:name=".AppDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN"
            android:exported="true">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin_receiver" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
            </intent-filter>
        </receiver>

        <service
            android:name=".OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="Floating watermark/logo overlay windows requested by the user" />
        </service>

        <receiver
            android:name=".BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

    </application>
</manifest>
